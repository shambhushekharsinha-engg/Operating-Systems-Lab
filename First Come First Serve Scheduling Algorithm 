=== "Python"
    ```python
    def find_fcfs(processes, at, bt):
        n = len(processes)
        ct = [0] * n
        tat = [0] * n
        wt = [0] * n

        ct[0] = at[0] + bt[0]
        for i in range(1, n):
            ct[i] = max(at[i], ct[i-1]) + bt[i]

        print("PID\tAT\tBT\tCT\tTAT\tWT")
        total_wt, total_tat = 0, 0
        for i in range(n):
            tat[i] = ct[i] - at[i]
            wt[i] = tat[i] - bt[i]
            total_wt += wt[i]
            total_tat += tat[i]
            print(f"{processes[i]}\t{at[i]}\t{bt[i]}\t{ct[i]}\t{tat[i]}\t{wt[i]}")

        print(f"\nAverage Waiting Time = {total_wt / n:.2f}")
        print(f"Average Turnaround Time = {total_tat / n:.2f}")

    if __name__ == "__main__":
        processes = [1, 2, 3]
        arrival_time = [0, 1, 2]
        burst_time = [10, 5, 8]
        find_fcfs(processes, arrival_time, burst_time)
