list.add(new Process(1, 10, 2));
list.add(new Process(2, 5, 0));
list.add(new Process(3, 8, 1));
list.sort(Comparator.comparingInt(p -> p.priority));
int current_time = 0;
float total_wt = 0, total_tat = 0;
System.out.println("PID\tPriority\tBT\tCT\tTAT\tWT");
for (Process p : list) {
current_time += p.bt;
p.ct = current_time;
p.tat = p.ct;
p.wt = p.tat - p.bt;
total_wt += p.wt;
total_tat += p.tat;
