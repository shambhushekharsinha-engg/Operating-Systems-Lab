Processes are allocated the CPU based on highest priority (Lower integer = Higher priority).
Code Implementations
=== "C"
```c

#include <stdio.h>
struct Process {
int pid, bt, priority, wt, tat, ct;
};
void priorityScheduling(struct Process p[], int n) {
// Simple selection sort based on priority (assumes simultaneous arrival at 0)
for (int i = 0; i < n - 1; i++) {
for (int j = i + 1; j < n; j++) {
if (p[i].priority > p[j].priority) {
struct Process temp = p[i];
p[i] = p[j];
p[j] = temp;
}
}
}
int current_time = 0;
float total_wt = 0, total_tat = 0;
printf("PID\tPriority\tBT\tCT\tTAT\tWT\n");
for (int i = 0; i < n; i++) {
current_time += p[i].bt;
p[i].ct = current_time;
p[i].tat = p[i].ct;
p[i].wt = p[i].tat - p[i].bt;
total_wt += p[i].wt;
total_tat += p[i].tat;
printf("%d\t%d\t\t%d\t%d\t%d\t%d\n", p[i].pid, p[i].priority, p[i].bt, p[i].ct, p[i].tat, p[i].wt);
}
printf("\nAverage Waiting Time = %.2f", total_wt / n);
printf("\nAverage Turnaround Time = %.2f\n", total_tat / n);
}
int main() {
struct Process p[] = {{1, 10, 2}, {2, 5, 0}, {3, 8, 1}};
int n = sizeof(p) / sizeof(p[0]);
priorityScheduling(p, n);
return 0;
}
```
=== "C++"
```cpp

#include <iostream>
#include <vector>
#include <algorithm>
#include <iomanip>
using namespace std;
struct Process {
int pid, bt, priority, ct, tat, wt;
};
void priorityScheduling(vector<Process>& vec) {
sort(vec.begin(), vec.end(), [](const Process& a, const Process& b) {
return a.priority < b.priority;
});
int current_time = 0;
float total_wt = 0, total_tat = 0;
cout << "PID\tPriority\tBT\tCT\tTAT\tWT\n";
for (auto& p : vec) {
current_time += p.bt;
p.ct = current_time;
p.tat = p.ct;
p.wt = p.tat - p.bt;
total_wt += p.wt;
total_tat += p.tat;
cout << p.pid << "\t" << p.priority << "\t\t" << p.bt << "\t" << p.ct << "\t" << p.tat << "\t" << p.wt << "\n";
}
cout << fixed << setprecision(2);
cout << "\nAverage Waiting Time = " << total_wt / vec.size();
cout << "\nAverage Turnaround Time = " << total_tat / vec.size() << "\n";
}
int main() {
vector<Process> vec = {{1, 10, 2}, {2, 5, 0}, {3, 8, 1}};
priorityScheduling(vec);
return 0;
}
